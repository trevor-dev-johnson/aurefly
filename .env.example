DATABASE_URL=postgres://solana_pay:solana_pay@localhost:5432/solana_pay
HOST=0.0.0.0
PORT=8080
ALLOWED_ORIGINS=https://aurefly.com,https://www.aurefly.com,http://localhost:3000,http://127.0.0.1:3000
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Backward-compatible fallback names also supported by the backend:
# SUPABASE_ANON_KEY=
# SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Leave SOLANA_RPC_URL blank to let the app derive a Helius mainnet URL from HELIUS_API_KEY.
# Or set SOLANA_RPC_URL directly to any dedicated Solana RPC endpoint.
SOLANA_RPC_URL=
HELIUS_API_KEY=
SOLANA_FALLBACK_RPC_URL=
SOLANA_FALLBACK_WS_URL=
TREASURY_WALLET_PATH=./data/treasury-wallet.json
# Optional: paste the full Solana keypair JSON array to avoid filesystem-backed secrets in production.
TREASURY_WALLET_JSON=
SOLANA_FEE_PAYER_PATH=
# Optional: paste the full Solana keypair JSON array for the ATA fee payer.
SOLANA_FEE_PAYER_JSON=
AUTH_RATE_LIMIT_MAX_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECS=60
PAYMENT_DETECTOR_POLL_INTERVAL_SECS=10
PAYMENT_DETECTOR_SIGNATURE_LIMIT=100
INVOICE_PENDING_TTL_SECS=1800
RUST_LOG=info
